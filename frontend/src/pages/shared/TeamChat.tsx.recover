53: const ReplyPreviewBlock = React.memo(({ 
54:   replyToMessageUuid, 
55:   replyToSenderName, 
56:   replyToContent, 
57:   roomMessages, 
58:   isMe, 
59:   onScrollTo, 
60:   inBubble = false,
61:   accessToken
62: }: {
63:   replyToMessageUuid: string;
64:   replyToSenderName?: string;
65:   replyToContent?: string;
66:   roomMessages: any[];
67:   isMe: boolean;
68:   onScrollTo?: (uuid: string) => void;
69:   inBubble?: boolean;
70:   accessToken?: string | null;
71: }) => {
72:   const repliedMsg = roomMessages.find(m => m.uuid === replyToMessageUuid);
73:   
74:   let type = 'text';
75:   let previewText = repliedMsg ? repliedMsg.content : replyToContent;
76:   let thumbnailUrl = null;
77: 
78:   if (repliedMsg) {
79:     if (repliedMsg.isVoiceNote) {
80:       type = 'voice';
81:       previewText = 'Voice message' + (repliedMsg.voiceNoteDuration ? ` (${Math.floor(repliedMsg.voiceNoteDuration)}s)` : '');
82:     } else if (repliedMsg.attachments && repliedMsg.attachments.length > 0) {
83:       const firstAtt = repliedMsg.attachments[0];
84:       if (firstAtt.fileType.startsWith('image/')) {
85:         type = 'image';
86:         previewText = previewText || 'Photo';
87:         thumbnailUrl = `${SERVER_BASE}${firstAtt.fileUrl}?access_token=${accessToken}`;
88:       } else {
89:         type = 'file';
90:         previewText = previewText || firstAtt.fileName;
91:       }
92:     }
93:   }
94: 
95:   const containerClass = inBubble 
96:     ? (isMe 
97:         ? "bg-white/10 hover:bg-white/20 border-l-4 border-[#a78bfa] text-white/90" 
98:         : "glass-surface hover:glass-surface dark:hover:bg-white/5 border-l-4 border-indigo-500 text-muted-foreground"
99:       )
100:     : "glass-surface/80 border-l-4 border-indigo-500 text-muted-foreground";
101: 
102:   const nameClass = inBubble 
103:     ? (isMe ? "text-white font-bold" : "text-primary dark:text-primary font-bold")
104:     : "text-primary dark:text-primary font-bold";
105: 
106:   return (
107:     <div 
108:       onClick={() => onScrollTo && onScrollTo(replyToMessageUuid)}
109:       className={`flex items-stretch justify-between rounded-md p-2 mb-2 cursor-pointer transition-colors ${containerClass} w-full min-w-0 sm:min-w-[200px]`}
110:     >
111:       <div className="flex flex-col min-w-0 pr-4 flex-1">
112:         <span className={`text-xs ${nameClass} mb-0.5`}>
113:           {replyToSenderName || (repliedMsg ? repliedMsg.senderName : 'Reply')}
114:         </span>
115:         <div className="flex items-center text-xs truncate opacity-90">
116:           {type === 'voice' && <Mic className="w-3.5 h-3.5 mr-1 flex-shrink-0" />}
117:           {type === 'image' && <Image className="w-3.5 h-3.5 mr-1 flex-shrink-0" />}
118:           {type === 'file' && <FileText className="w-3.5 h-3.5 mr-1 flex-shrink-0" />}
119:           <span className="truncate">{previewText?.substring(0, 50) || ''}</span>
120:         </div>
121:       </div>
122:       {thumbnailUrl && (
123:         <div className="flex-shrink-0 w-10 h-10 rounded overflow-hidden ml-2 /5">
124:           <img src={thumbnailUrl} alt="thumbnail" className="w-full h-full object-cover" />
125:         </div>
126:       )}
127:     </div>
128:   );
129: });
