28: const formatChatDate = (dateString: string) => {
29:   const d = new Date(dateString);
30:   const now = new Date();
31:   const isToday = d.getDate() === now.getDate() && d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
32:   
33:   const yesterday = new Date(now);
34:   yesterday.setDate(yesterday.getDate() - 1);
35:   const isYesterday = d.getDate() === yesterday.getDate() && d.getMonth() === yesterday.getMonth() && d.getFullYear() === yesterday.getFullYear();
36: 
37:   if (isToday) return 'Today';
38:   if (isYesterday) return 'Yesterday';
39:   return d.toLocaleDateString('en-US', { day: 'numeric', month: 'short' });
40: };
41: 
42: const formatChatTime = (dateString: string, includeRelative = false) => {
43:   const d = new Date(dateString);
44:   const timeStr = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
45:   if (includeRelative) {
46:     const rel = formatChatDate(dateString);
47:     if (rel !== 'Today') return `${rel} • ${timeStr}`;
48:   }
49:   return timeStr;
50: };
