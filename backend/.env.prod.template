# ─── Production Environment Template (Neon PostgreSQL) ───────────────────────
# Copy this file to .env.prod (or inject as environment variables in your
# deployment platform) and fill in the real values from your Neon dashboard.
# NEVER commit real credentials to version control.
#
# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Get these from: https://console.neon.tech → your project → Connection Details
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_URL=jdbc:postgresql://<neon-host>/<dbname>?sslmode=require
DATABASE_USERNAME=<neon-user>
DATABASE_PASSWORD=<neon-password>

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password>

# ─── Clerk ───────────────────────────────────────────────────────────────────
CLERK_ISSUER_URI=https://<your-clerk-subdomain>.clerk.accounts.dev
CLERK_JWK_SET_URI=https://<your-clerk-subdomain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=<clerk-webhook-secret>

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be a strong 256-bit (64 hex-char) secret — generate with:
# openssl rand -hex 32
JWT_SECRET=<strong-256-bit-hex-secret>

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ─── OpenAI (optional) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
